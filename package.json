{
  "name": "fyzzy-bridge",
  "version": "0.1.2",
  "private": true,
  "description": "Fyzzy Bridge — on-site collector that reads a Keiser A400 Hub over LAN and streams training data (live + daily export) to Fyzzy cloud. Runs on a Raspberry Pi. Pure-JS so it ships as a single OTA-updatable bundle.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/bundle.cjs",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/bundle.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "bonjour-service": "^1.2.1",
    "fastify": "^4.28.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.12",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
